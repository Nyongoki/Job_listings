  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"0712345678\",\n  \"password\": \"Password123\",\n  \"role\": \"freelancer\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "description": "Registers a new user (freelancer or employer). Checks validation constraints on name, email, phone format, and password complexity."
      },
      "response": []
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Logs in a user with email and password. Returns JWT access token (expires in 1hr) and a refresh token (expires in 7d)."
      },
      "response": []
    },
    {
      "name": "Auth - Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/refresh",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        },
        "description": "Submits a refresh token to obtain a new short-lived JWT access token."
      },
      "response": []
    },
    {
      "name": "Auth - Get Profile (Me)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        },
        "description": "Returns details of the currently authenticated user based on the JWT bearer token."
      },
      "response": []
    },
    {
      "name": "Jobs - List Jobs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/jobs?search=react&category=Web Development&location=Nairobi&budget_min=5000&budget_max=100000&sort=newest&page=1&limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "jobs"
          ],
          "query": [
            {
              "key": "search",
              "value": "react"
            },
            {
              "key": "category",
              "value": "Web Development"
            },
            {
              "key": "location",
              "value": "Nairobi"
            },
            {
              "key": "budget_min",
              "value": "5000"
            },
            {
              "key": "budget_max",
              "value": "100000"
            },
            {
              "key": "sort",
              "value": "newest"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Fetches a paginated, filterable, and sorted list of all active jobs, including proposal counts for each job."
      },
      "response": []
    },
    {
      "name": "Jobs - Create Job",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"React Developer\",\n  \"description\": \"Looking for a developer to implement interactive React interfaces using Tailwind CSS. Must have 2 years experience.\",\n  \"category\": \"Web Development\",\n  \"location\": \"Nairobi\",\n  \"budget\": 75000,\n  \"skills\": [\"React\", \"Tailwind CSS\", \"JavaScript\"],\n  \"deadline\": \"2026-08-30\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/jobs",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "jobs"
          ]
        },
        "description": "Creates a new job listing. Restricted to users with the 'employer' role."
      },
      "response": []
    },
    {
      "name": "Jobs - Get Single Job",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/jobs/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "jobs",
            "1"
          ]
        },
        "description": "Fetches detailed information for a single job listing, including the current proposal count."
      },
      "response": []
    },
    {
      "name": "Jobs - Submit Proposal",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cover_letter\": \"Hello, I am a seasoned React engineer with extensive Tailwind v4 and responsive UI development skills. I would love to build this.\",\n  \"proposed_budget\": 70000,\n  \"timeline_days\": 14,\n  \"portfolio_url\": \"https://myportfolio.com/jane\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/jobs/1/proposals",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "jobs",
            "1",
            "proposals"
          ]
        },
        "description": "Submits a freelancer proposal for a specific job. Restricted to the 'freelancer' role. Each freelancer can submit only one proposal per job."
      },
      "response": []
    },
    {
      "name": "Jobs - Accept Proposal",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/jobs/1/proposals/1/accept",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "jobs",
            "1",
            "proposals",
            "1",
            "accept"
          ]
        },
        "description": "Accepts a proposal for a job. Automatically marks all alternative proposals as rejected, sets the job status to 'in_progress', and creates a contract record with status 'pending'."
      },
      "response": []
    },
    {
      "name": "Escrow - Fund Contract",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/contracts/1/fund",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "contracts",
            "1",
            "fund"
          ]
        },
        "description": "Funds a pending contract escrow. Changes contract status to 'funded', saves a funded timestamp, and generates a mock checkout request ID. Restricted to the employer."
      },
      "response": []
    },
    {
      "name": "Escrow - Deliver Contract",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/contracts/1/deliver",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "contracts",
            "1",
            "deliver"
          ]
        },
        "description": "Marks a contract as delivered by the freelancer. Changes contract status from 'funded' to 'delivered'. Restricted to the freelancer."
      },
      "response": []
    },
    {
      "name": "Escrow - Approve & Release",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/contracts/1/approve",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "contracts",
            "1",
            "approve"
          ]
        },
        "description": "Approves a delivered contract. Splites payment (92% payout to freelancer, 8% platform fee), records two payment rows, and changes contract status to 'released'. Restricted to the employer."
      },
      "response": []
    },
    {
      "name": "Escrow - Raise Dispute",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"The freelancer failed to implement mobile layouts and left the project incomplete.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/contracts/1/dispute",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "contracts",
            "1",
            "dispute"
          ]
        },
        "description": "Raises a dispute on a contract. Status changes to 'disputed'. Accessible by either the employer or the freelancer on the contract."
      },
      "response": []
    }
  ]
}
